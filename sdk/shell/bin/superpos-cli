#!/usr/bin/env bash
# superpos-cli — Command-line wrapper for the Superpos Shell SDK.
#
# Usage:
#   superpos-cli <command> [options]
#
# Commands:
#   register      Register a new agent
#   login         Authenticate an existing agent
#   logout        Revoke the current token
#   me            Show current agent profile
#   heartbeat     Send heartbeat
#   status        Update agent status
#   drain         Enter drain mode
#   undrain       Exit drain mode
#   drain-status  Show drain status
#   key-rotate    Rotate API key
#   key-revoke    Revoke previous (grace) key
#   key-status    Show key rotation status
#   task-create   Create a task
#   task-poll     Poll for available tasks
#   task-claim    Claim a pending task
#   task-progress Update task progress
#   task-complete Complete a task
#   task-fail     Fail a task
#   schedule-list     List task schedules
#   schedule-get      Get a task schedule
#   schedule-create   Create a task schedule
#   schedule-update   Update a task schedule
#   schedule-delete   Delete a task schedule
#   schedule-pause    Pause a task schedule
#   schedule-resume   Resume a task schedule
#   knowledge-list    List knowledge entries
#   knowledge-search  Search knowledge entries
#   knowledge-get     Get a knowledge entry
#   knowledge-create  Create a knowledge entry
#   knowledge-update  Update a knowledge entry
#   knowledge-delete  Delete a knowledge entry
#   persona-get-version   Get server-assigned persona version (lightweight)
#   persona-check-version Check if persona version has changed (-k KNOWN_VERSION)
#   persona-get           Get active persona
#   persona-get-config    Get persona config
#   persona-get-document  Get a persona document by name
#   persona-get-assembled Get pre-assembled system prompt
#   persona-update-document Update a persona document
#   persona-update-memory   Update the MEMORY document (append by default)
#   version       Show SDK version
#
# Environment:
#   SUPERPOS_BASE_URL   API base URL (required)
#   SUPERPOS_TOKEN      Bearer token (or use register/login first)
#   SUPERPOS_TIMEOUT    Request timeout in seconds (default: 30)
#   SUPERPOS_DEBUG      Set to 1 for verbose output

set -euo pipefail

# Resolve SDK path relative to this script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SDK_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# shellcheck source=../src/superpos-sdk.sh
# Guard against re-sourcing (e.g., when superpos-cli is itself sourced in tests
# that have already loaded superpos-sdk.sh — re-sourcing would fail on the
# readonly variable declarations).
# Use a function-presence check rather than an environment variable so that
# an inherited SUPERPOS_OK=1 from the caller's environment cannot accidentally
# skip loading the SDK and leave superpos_check_deps undefined.
if ! declare -F superpos_check_deps >/dev/null 2>&1; then
    source "${SDK_DIR}/src/superpos-sdk.sh"
fi

_cli_usage() {
    echo "Usage: superpos-cli <command> [options]"
    echo ""
    echo "Commands:"
    echo "  register         Register a new agent"
    echo "  login            Authenticate an existing agent"
    echo "  logout           Revoke the current token"
    echo "  me               Show current agent profile"
    echo "  heartbeat        Send heartbeat"
    echo "  status           Update agent status"
    echo "  drain            Enter drain mode"
    echo "  undrain          Exit drain mode"
    echo "  drain-status     Show drain status"
    echo "  key-rotate       Rotate API key"
    echo "  key-revoke       Revoke previous (grace) key"
    echo "  key-status       Show key rotation status"
    echo "  task-create      Create a task"
    echo "  task-poll        Poll for available tasks"
    echo "  task-claim       Claim a pending task"
    echo "  task-progress    Update task progress"
    echo "  task-complete    Complete a task"
    echo "  task-fail        Fail a task"
    echo "  schedule-list    List task schedules"
    echo "  schedule-get     Get a task schedule"
    echo "  schedule-create  Create a task schedule"
    echo "  schedule-update  Update a task schedule"
    echo "  schedule-delete  Delete a task schedule"
    echo "  schedule-pause   Pause a task schedule"
    echo "  schedule-resume  Resume a task schedule"
    echo "  knowledge-list   List knowledge entries"
    echo "  knowledge-search Search knowledge entries"
    echo "  knowledge-get    Get a knowledge entry"
    echo "  knowledge-create Create a knowledge entry"
    echo "  knowledge-update Update a knowledge entry"
    echo "  knowledge-delete Delete a knowledge entry"
    echo "  persona-get-version   Get server-assigned persona version (lightweight)"
    echo "  persona-check-version Check if persona version has changed (-k KNOWN_VERSION)"
    echo "  persona-get           Get active persona"
    echo "  persona-get-config    Get persona config"
    echo "  persona-get-document  Get a persona document by name"
    echo "  persona-get-assembled Get pre-assembled system prompt"
    echo "  persona-update-document Update a persona document"
    echo "  persona-update-memory   Update the MEMORY document (append by default)"
    echo "  version          Show SDK version"
    echo ""
    echo "Environment:"
    echo "  SUPERPOS_BASE_URL  API base URL (required)"
    echo "  SUPERPOS_TOKEN     Bearer token"
    echo "  SUPERPOS_TIMEOUT   Request timeout in seconds (default: 30)"
    echo "  SUPERPOS_DEBUG     Set to 1 for verbose output"
}

_cli_register_usage() {
    echo "Usage: superpos-cli register -n NAME -h HIVE_ID -s SECRET [-a SUPERPOS_ID] [-t TYPE] [-c CAPABILITIES_JSON] [-m METADATA_JSON]"
}

_cli_login_usage() {
    echo "Usage: superpos-cli login -i AGENT_ID -s SECRET"
}

_cli_task_create_usage() {
    echo "Usage: superpos-cli task-create HIVE_ID -t TYPE [-p PRIORITY] [-a TARGET_AGENT_ID] [-c TARGET_CAPABILITY] [-d PAYLOAD_JSON] [-T TIMEOUT] [-r MAX_RETRIES] [-P PARENT_TASK_ID] [-x CONTEXT_REFS_JSON] [-g GUARANTEE] [-e EXPIRES_AT] [-I INVOKE_INSTRUCTIONS] [-X INVOKE_CONTEXT_JSON]"
}

_cli_dispatch() {
if [[ $# -lt 1 ]]; then
    _cli_usage
    return 1
fi

local command="$1"
shift

case "$command" in
    register)
        [[ $# -eq 0 ]] && { _cli_register_usage; return 1; }
        superpos_register "$@"
        superpos_save_token
        ;;
    login)
        [[ $# -eq 0 ]] && { _cli_login_usage; return 1; }
        superpos_login "$@"
        superpos_save_token
        ;;
    logout)
        _logout_rc=0
        superpos_logout || _logout_rc=$?
        superpos_clear_token_file
        [[ $_logout_rc -ne 0 ]] && return "$_logout_rc"
        ;;
    me)
        superpos_me
        ;;
    heartbeat)
        superpos_heartbeat "$@"
        ;;
    status)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli status STATUS" >&2
            return 1
        fi
        superpos_update_status "$1"
        ;;
    drain)
        superpos_enter_drain "$@"
        ;;
    undrain)
        superpos_exit_drain
        ;;
    drain-status)
        superpos_drain_status
        ;;
    key-rotate)
        [[ $# -eq 0 ]] && { echo "Usage: superpos-cli key-rotate -s NEW_SECRET [-g GRACE_PERIOD_MINUTES]" >&2; return 1; }
        superpos_rotate_key "$@"
        superpos_save_token
        ;;
    key-revoke)
        superpos_revoke_previous_key
        ;;
    key-status)
        superpos_key_status
        ;;
    task-create)
        if [[ $# -lt 1 ]]; then
            _cli_task_create_usage
            return 1
        fi
        superpos_create_task "$@"
        ;;
    task-poll)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli task-poll HIVE_ID [-c CAPABILITY] [-l LIMIT]" >&2
            return 1
        fi
        superpos_poll_tasks "$@"
        ;;
    task-claim)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli task-claim HIVE_ID TASK_ID" >&2
            return 1
        fi
        superpos_claim_task "$@"
        ;;
    task-progress)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli task-progress HIVE_ID TASK_ID -p PROGRESS [-m MESSAGE]" >&2
            return 1
        fi
        superpos_update_progress "$@"
        ;;
    task-complete)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli task-complete HIVE_ID TASK_ID [-r RESULT_JSON] [-m MESSAGE]" >&2
            return 1
        fi
        superpos_complete_task "$@"
        ;;
    task-fail)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli task-fail HIVE_ID TASK_ID [-e ERROR_JSON] [-m MESSAGE]" >&2
            return 1
        fi
        superpos_fail_task "$@"
        ;;
    schedule-list)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli schedule-list HIVE_ID [-s STATUS]" >&2
            return 1
        fi
        superpos_list_schedules "$@"
        ;;
    schedule-get)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli schedule-get HIVE_ID SCHEDULE_ID" >&2
            return 1
        fi
        superpos_get_schedule "$@"
        ;;
    schedule-create)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli schedule-create HIVE_ID -n NAME -g TRIGGER_TYPE -t TASK_TYPE [...]" >&2
            return 1
        fi
        superpos_create_schedule "$@"
        ;;
    schedule-update)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli schedule-update HIVE_ID SCHEDULE_ID [-n NAME] [-g TRIGGER_TYPE] [...]" >&2
            return 1
        fi
        superpos_update_schedule "$@"
        ;;
    schedule-delete)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli schedule-delete HIVE_ID SCHEDULE_ID" >&2
            return 1
        fi
        superpos_delete_schedule "$@"
        ;;
    schedule-pause)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli schedule-pause HIVE_ID SCHEDULE_ID" >&2
            return 1
        fi
        superpos_pause_schedule "$@"
        ;;
    schedule-resume)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli schedule-resume HIVE_ID SCHEDULE_ID" >&2
            return 1
        fi
        superpos_resume_schedule "$@"
        ;;
    knowledge-list)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli knowledge-list HIVE_ID [-k KEY] [-s SCOPE] [-l LIMIT]" >&2
            return 1
        fi
        superpos_list_knowledge "$@"
        ;;
    knowledge-search)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli knowledge-search HIVE_ID [-q QUERY] [-s SCOPE] [-l LIMIT]" >&2
            return 1
        fi
        superpos_search_knowledge "$@"
        ;;
    knowledge-get)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli knowledge-get HIVE_ID ENTRY_ID" >&2
            return 1
        fi
        superpos_get_knowledge "$@"
        ;;
    knowledge-create)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli knowledge-create HIVE_ID -k KEY -v VALUE_JSON [-s SCOPE] [-V VISIBILITY] [-t TTL]" >&2
            return 1
        fi
        superpos_create_knowledge "$@"
        ;;
    knowledge-update)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli knowledge-update HIVE_ID ENTRY_ID -v VALUE_JSON [-V VISIBILITY] [-t TTL]" >&2
            return 1
        fi
        superpos_update_knowledge "$@"
        ;;
    knowledge-delete)
        if [[ $# -lt 2 ]]; then
            echo "Usage: superpos-cli knowledge-delete HIVE_ID ENTRY_ID" >&2
            return 1
        fi
        superpos_delete_knowledge "$@"
        ;;
    persona-get-version)
        superpos_get_persona_version "$@"
        ;;
    persona-check-version)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli persona-check-version -k KNOWN_VERSION" >&2
            return 1
        fi
        # superpos_check_persona_version returns 1 for the legitimate "unchanged"
        # case and 2+ for real errors.  Under set -e a non-zero return kills the
        # process before _rc=$? is reached, so we must disable errexit for this
        # call.  Using "|| _rc=$?" alone is insufficient when _rc is unset and the
        # command succeeds (rc=0), so we initialise _rc=0 first.
        _rc=0
        superpos_check_persona_version "$@" || _rc=$?
        if [[ $_rc -eq 0 ]]; then
            echo "changed"
        elif [[ $_rc -eq 1 ]]; then
            echo "unchanged"
            return 1
        else
            return $_rc
        fi
        ;;
    persona-get)
        superpos_get_persona
        ;;
    persona-get-config)
        superpos_get_persona_config
        ;;
    persona-get-document)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli persona-get-document NAME" >&2
            return 1
        fi
        superpos_get_persona_document "$@"
        ;;
    persona-get-assembled)
        superpos_get_persona_assembled
        ;;
    persona-update-document)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli persona-update-document NAME -c CONTENT [-m MESSAGE]" >&2
            return 1
        fi
        superpos_update_persona_document "$@"
        ;;
    persona-update-memory)
        if [[ $# -lt 1 ]]; then
            echo "Usage: superpos-cli persona-update-memory -c CONTENT [-m MESSAGE] [-M MODE]" >&2
            return 1
        fi
        superpos_update_memory "$@"
        ;;
    rate-limit-status)
        superpos_rate_limit_status
        ;;
    rate-limit-update)
        [[ $# -eq 0 ]] && { echo "Usage: superpos-cli rate-limit-update -l LIMIT (or -l null)" >&2; return 1; }
        superpos_update_rate_limit "$@"
        ;;
    version)
        echo "superpos-sdk ${SUPERPOS_SDK_VERSION}"
        ;;
    help|--help|-h)
        _cli_usage
        ;;
    *)
        echo "Unknown command: $command" >&2
        _cli_usage >&2
        return 1
        ;;
esac
}

# Run the dispatch when executed directly (not sourced for testing).
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    # Check dependencies and load persisted token only at the entrypoint.
    superpos_check_deps || exit $?
    superpos_load_token
    _cli_dispatch "$@"
fi
